@article{carreresTypeIaSupernova2025,
  title = {Type {{Ia Supernova Growth-rate Measurement}} with {{LSST Simulations}}: {{Intrinsic Scatter Systematics}}},
  shorttitle = {Type {{Ia Supernova Growth-rate Measurement}} with {{LSST Simulations}}},
  author = {Carreres, Bastien and Chen, Rebecca C. and Peterson, Erik R. and Scolnic, Dan and Ravoux, Corentin and Rosselli, Damiano and Acevedo, Maria and Bautista, Julian E. and Fouchez, Dominique and Galbany, Lluís and Racine, Benjamin and Collaboration, The LSST Dark Energy Science},
  date = {2025-11},
  journaltitle = {The Astrophysical Journal},
  shortjournal = {ApJ},
  volume = {994},
  number = {2},
  pages = {178},
  publisher = {The American Astronomical Society},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/ae11ac},
  langid = {english},
  keywords = {Astrophysics - Cosmology and Nongalactic Astrophysics,FirstAuth},
  annotation = {Je suis l'auteur principal de cette publication. Dans cet article, j’étudie l’impact de la dispersion intrinsèque des SNe~Ia sur la mesure de $f\sigma_8$. Cette étude est réalisée à l'aide d'une simulation du jeu de données des SNe~Ia à bas \textit{redshift} ($z<0.15$) du relevé Rubin-LSST pour différents modèles de dispersion intrinsèque. J'ai montré que le modèle de dispersion intrinsèque le plus réaliste induit des non-gaussianités dans les résidus du diagramme de Hubble, ce qui entraîne un biais sur $f\sigma_8$. Je montre également que l'erreur sur $f\sigma_8$ est dominée par l'erreur statistique ($>75\%$ de l'erreur totale) et que la source principale d'erreur systématique est liée à la modélisation des distorsions de l'espace des \textit{redshifts} dans le spectre de puissance des vitesses.}},
  keywords = {FirstAuth,selected},
  selected = {true},
  inspirehep_id = {2922983},
  ads_bibcode = {2025arXiv250513290C}
}

@article{carreresztfsnia2025,
  title = {ZTF SN Ia DR2: Peculiar velocities' impact on the Hubble diagram},
  author = {Carreres, B. and Rosselli, D. and Bautista, J. E. and Feinstein, F. and Fouchez, D. and Racine, B. and Ravoux, C. and Sanchez, B. and Dimitriadis, G. and Goobar, A. and Johansson, J. and Nordin, J. and Rigault, M. and Smith, M. and Amenouche, M. and Aubert, M. and Barjou-Delayre, C. and Burgaz, U. and Kenworthy, W. D’Arcy and Jaeger, T. De and Dhawan, S. and Galbany, L. and Ginolin, M. and Kuhn, D. and Kowalski, M. and Müller-Bravo, T. E. and Nugent, P. E. and Popovic, B. and Rosnet, P. and Ruppin, F. and Sollerman, J. and Terwel, J. H. and Townsend, A. and Groom, S. L. and Kulkarni, S. R. and Purdum, J. and Rusholme, B. and Sravan, N.},
  year = {2025},
  month = {02},
  journal = {Astronomy \& Astrophysics},
  doi = {10.1051/0004-6361/202450389},
  preprint = {https://arxiv.org/abs/2505.13290},
  annotation = {Je suis l'auteur principal de cette publication. Cet article fait partie de l'édition spéciale \href{https://www.aanda.org/component/toc/?task=topic&id=2090}{\textit{ZTF SN Ia DR2}} publiée par \textit{Astronomy \& Astrophysics}. Dans ce travail, j’étudie l’impact des effets systématiques liés aux vitesses particulières (PV) sur le diagramme de Hubble du jeu de données ``ZTF SN~Ia DR2''. À l'aide de simulations et des données de ZTF, je montre que ne pas prendre en compte la matrice de covariance complète des vitesses particulières peut conduire à une légère sous-estimation de l’erreur sur la constante de Hubble $H_0$ et changer sa valeur mesurée de $\sim 1\,\mathrm{km\,s^{-1}}$.},
  keywords = {FirstAuth,selected},
  selected = {true},
  inspirehep_id = {2793068},
  ads_bibcode={2025A\&A...694A...8C}
}

@article{carreresgromeawit2023,
  title = {Growth-rate measurement with type-Ia supernovae using ZTF survey simulations},
  author = {Carreres, Bastien and Bautista, Julian E. and Feinstein, Fabrice and Fouchez, Dominique and Racine, Benjamin and Smith, Mathew and Amenouche, Melissa and Aubert, Marie and Dhawan, Suhail and Ginolin, Madeleine and Goobar, Ariel and Gris, Philippe and Lacroix, Leander and Nuss, Eric and Regnault, Nicolas and Rigault, Mickael and Robert, Estelle and Rosnet, Philippe and Sommer, Kelian and Dekany, Richard and Groom, Steven L. and Sravan, Niharika and Masci, Frank J. and Purdum, Josiah},
  year = {2023},
  month = {06},
  journal = {Astronomy \& Astrophysics},
  doi = {10.1051/0004-6361/202346173},
  preprint = {https://arxiv.org/abs/2303.01198},
  annotation = {Ce papier est la publication principale de ma thèse. Dans celui-ci, je présente mon travail pour préparer la future mesure du taux de croissance des structures ($f\sigma_8$) avec les données des SNe Ia de ZTF. J'y décris ma simulation réaliste du jeu de données de ZTF. Avec cette simulation, j'étudie l'impact du biais de sélection de classification spectroscopique sur la mesure de $f\sigma_8$. Je montre que, les données des SNe Ia des six ans du relevé ZTF, coupées à un \textit{redshift} $z <0.06$ pour éviter le biais de sélection, vont permettre de mesurer $f\sigma_8$ avec une précision de $\sim19\%$.},
  keywords = {FirstAuth,selected},
  selected = {true},
  inspirehep_id = {2638123},
  ads_bibcode = {2023A\&A...674A.197C}
}

